DJANGO_SECRET_KEY=replace-me-with-long-random-secret
DJANGO_ENV=production
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-app.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>
DATABASE_SSL_REQUIRE=1
DJANGO_SECURE_SSL_REDIRECT=1

# Cookie strategy:
# - Same domain frontend+backend: keep Lax.
# - Cross-site frontend/backend (different site): set both to None and keep secure=1.
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
